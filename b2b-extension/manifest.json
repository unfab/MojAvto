{
  "manifest_version": 3,
  "name": "MojAvto — Uvozni kalkulator",
  "version": "1.0.0",
  "description": "Analiziraj vozilo na Mobile.de in uvozi podatke v MojAvto B2B kalkulator.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*.mobile.de/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
